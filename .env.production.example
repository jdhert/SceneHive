# SceneHive Production Environment Variables
# Copy this file to your production server as .env and fill in the values

# Database
DB_USER=postgres
DB_PASSWORD=your_production_db_password
DB_NAME=scenehive

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_SECRET=your_production_jwt_secret_min_256_bits
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

# Mail (Gmail SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# OAuth - Google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-production-domain/login/oauth2/code/google

# OAuth - Kakao
KAKAO_CLIENT_ID=your_kakao_client_id
KAKAO_CLIENT_SECRET=your_kakao_client_secret

# OAuth - Naver
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# URLs
FRONTEND_URL=https://your-production-domain
BACKEND_URL=http://localhost:8081
CORS_ALLOWED_ORIGINS=https://your-production-domain
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p
NEXT_PUBLIC_OAUTH_BASE_URL=
